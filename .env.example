# Barry's Bootcamp Login Credentials
BARRYS_EMAIL=your-email@example.com
BARRYS_PASSWORD=your-password-here

# Booking Preferences
BARRYS_STUDIO=noho
BARRYS_CLASS_TIME=07:20
BARRYS_DAY=thursday
BARRYS_SPOTS=DF-33,DF-32,DF-30,DF-29,DF-26,DF-27,DF-28

# Timezone
TZ=America/New_York

# --- Dry-run mode (only for the Wednesday test cron) ---
# When "true", after a successful booking the script cancels the reservation.
# Used by the Wednesday cron to verify the booking flow a day before the real
# Thursday booking window.
CANCEL_AFTER_BOOKING=false

# Alert email — only used if CANCEL_AFTER_BOOKING=true and cancellation fails
# after 5 retries. Uses Gmail SMTP. Create an app password at
# https://myaccount.google.com/apppasswords.
ALERT_EMAIL_TO=stu@setpoint.io
ALERT_EMAIL_FROM=your-gmail-address@gmail.com
ALERT_EMAIL_APP_PASSWORD=your-16-char-app-password
